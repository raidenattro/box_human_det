# 复制为 .env 后 docker compose up -d 自动注入
APT_MIRROR=mirrors.aliyun.com
PIP_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
REDIS_PASSWORD=change-me

# Docker 构建：GitHub / Google Storage 加速（153 推荐 ghfast.top，末尾勿加 /）
GITHUB_PROXY_BASE=https://ghfast.top

# 构建专用 HTTP 代理（153 公司代理填这里；WSL 勿用下面 HTTP_PROXY 项）
# BUILD_HTTP_PROXY=http://192.168.1.1:7890
# BUILD_HTTPS_PROXY=http://192.168.1.1:7890

# 仅 WSL 拉 docker 镜像：可配合 ~/bin/update-docker-proxy.sh
# HTTP_PROXY=http://172.26.128.1:7078
# HTTPS_PROXY=http://172.26.128.1:7078

# Docker Hub 镜像：sudo cp deploy/docker-daemon-mirror.json.example /etc/docker/daemon.json && sudo systemctl restart docker

UI_PORT=8045
MEDIAMTX_PUBLIC_HOST=127.0.0.1
MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_WEBRTC_PORT=8889
# WebRTC ICE（UDP+TCP 均需映射到 mediamtx 容器 8189）
MEDIAMTX_WEBRTC_ICE_PORT=8189

# 推理镜像（UI 拉起检测容器时使用；WSL 无 GPU 时请保持 0）
INFERENCE_USE_GPU=0
INFERENCE_LITE_GPU_IMAGE=visual-dps-inference-lite-gpu:latest
INFERENCE_LITE_IMAGE=visual-dps-inference-lite:latest
