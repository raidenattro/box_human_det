# 153 物理机部署示例：复制为项目根 .env
APT_MIRROR=mirrors.aliyun.com
PIP_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
GITHUB_PROXY_BASE=https://ghfast.top

# 可选：构建时走公司 HTTP 代理（勿填 WSL 的 172.26.x）
# BUILD_HTTP_PROXY=http://192.168.1.1:7890
# BUILD_HTTPS_PROXY=http://192.168.1.1:7890

INFERENCE_USE_GPU=1
# 构建脚本输出带日期 tag，勿仅用 latest（见 AGENTS.md）
# INFERENCE_LITE_GPU_ONNX_IMAGE=visual-dps-inference-lite-gpu-onnx:20260528-120000-5eae119
UI_PORT=8046
MEDIAMTX_PUBLIC_HOST=192.168.1.153
REDIS_PASSWORD=change-me

# 勿在 153 上启用 WSL 代理项
# HTTP_PROXY=
# HTTPS_PROXY=
