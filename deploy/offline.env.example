# 离线包目标机 .env 示例（复制为 app/.env 或由 install.sh --host 自动改写）
APT_MIRROR=mirrors.aliyun.com
PIP_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
GITHUB_PROXY_BASE=https://ghfast.top

REDIS_PASSWORD=change-me-before-install
UI_PORT=8045
MEDIAMTX_PUBLIC_HOST=192.168.0.204
MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_WEBRTC_PORT=8889
MEDIAMTX_WEBRTC_ICE_PORT=8189

INFERENCE_USE_GPU=1
INFERENCE_LITE_IMAGE=visual-dps-inference-lite:latest
INFERENCE_LITE_GPU_IMAGE=visual-dps-inference-lite-gpu:latest
INFERENCE_LITE_GPU_ONNX_IMAGE=visual-dps-inference-lite-gpu-onnx:latest
INFERENCE_BACKEND=rtmpose_t

# 避免 docker-compose v1 解析完整 compose 时报错（deploy 文件不需要）
VISUAL_DPS_IMAGE_TAG=latest
