# syntax=docker/dockerfile:1
# 在 lite-gpu 上增量：单次 torch(cu121) + ORT + ultralytics(--no-deps)，pip 层可缓存
# 构建: ./scripts/build-inference-lite-gpu-onnx-image.sh

ARG BASE_IMAGE=visual-dps-inference-lite-gpu:latest
FROM ${BASE_IMAGE}

ARG PIP_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
ARG TORCH_INDEX=https://mirror.sjtu.edu.cn/pytorch-wheels/cu121
ARG TORCH_VERSION=2.5.1
ARG TORCHVISION_VERSION=0.20.1
ARG ORT_GPU_VERSION=1.20.2
ARG ULTRALYTICS_VERSION=8.4.0
ARG HTTP_PROXY=
ARG HTTPS_PROXY=

ENV http_proxy=${HTTP_PROXY} \
    https_proxy=${HTTPS_PROXY} \
    HTTP_PROXY=${HTTP_PROXY} \
    HTTPS_PROXY=${HTTPS_PROXY} \
    TORCH_VERSION=${TORCH_VERSION} \
    TORCHVISION_VERSION=${TORCHVISION_VERSION} \
    ORT_GPU_VERSION=${ORT_GPU_VERSION} \
    ULTRALYTICS_VERSION=${ULTRALYTICS_VERSION}

WORKDIR /app

COPY docker/probe-torch-index.sh docker/install-gpu-onnx-pip.sh /tmp/
RUN --mount=type=cache,target=/root/.cache/pip \
    chmod +x /tmp/probe-torch-index.sh /tmp/install-gpu-onnx-pip.sh \
    && TORCH_INDEX="${TORCH_INDEX}" /tmp/install-gpu-onnx-pip.sh "${PIP_INDEX}" \
    && rm -f /tmp/probe-torch-index.sh /tmp/install-gpu-onnx-pip.sh

COPY services ./services
COPY core ./core
COPY version.json ./version.json
COPY inference_worker.py ./inference_worker.py
